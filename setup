#!/usr/bin/env bash
# setup — make Elektra Skills binaries executable and validate install
set -euo pipefail

ELEKTRA_DIR="$(cd "$(dirname "$0")" && pwd)"

# Make binaries executable
if [ -d "$ELEKTRA_DIR/bin" ]; then
  chmod +x "$ELEKTRA_DIR/bin/"* 2>/dev/null || true
fi

# Make hooks executable
if [ -d "$ELEKTRA_DIR/.claude/hooks" ]; then
  chmod +x "$ELEKTRA_DIR/.claude/hooks/"* 2>/dev/null || true
fi

# Make setup itself executable (for future upgrades)
chmod +x "$ELEKTRA_DIR/setup" 2>/dev/null || true

# Create state directory
mkdir -p "$HOME/.elektra"

# Set sensible default config (update notifications ON)
# Guarded: skip if config already exists, don't fail setup if write errors
if [ ! -f "$HOME/.elektra/config.yaml" ]; then
  "$ELEKTRA_DIR/bin/elektra-config" set update_check true 2>/dev/null || true
fi

# Count installed skills
SKILL_COUNT=$(find "$ELEKTRA_DIR" -maxdepth 2 -name "SKILL.md" 2>/dev/null | wc -l | tr -d ' ')
VERSION=$(cat "$ELEKTRA_DIR/VERSION" 2>/dev/null || echo "unknown")

echo ""
printf "  ╭%s╮\n" "$(printf '─%.0s' {1..48})"
printf "  │  %-44s  │\n" "Elektra v${VERSION}"
printf "  │  %-44s  │\n" "Solutions Architect by Citadel Agentic Labs"
printf "  ╰%s╯\n" "$(printf '─%.0s' {1..48})"
echo ""
echo "  ${SKILL_COUNT} skills · hooks active · config ready"
echo ""
echo "  Next step: start a Claude Code session in any project."
echo "  Onboarding runs automatically on first session."
echo "  To re-run later: /init-elektra"
echo ""
